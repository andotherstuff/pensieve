# Pensieve — LOCAL development environment template
#
# Copy to .env at the repo root for local native runs:
#   cp env.local.example .env
#
# These variables are read by the binaries when run via `just run-serve`
# (and the preview server). The ingester is configured via CLI flags —
# see `just run-ingest -- --help`.
#
# For the PRODUCTION (Docker + systemd) stack, use env.production.example instead.

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── ClickHouse (point at your own local or remote instance) ──────────────────
CLICKHOUSE_URL=http://localhost:8123
# NOTE: the binaries read CLICKHOUSE_DATABASE (not CLICKHOUSE_DB).
CLICKHOUSE_DATABASE=nostr

# ── API server (pensieve-serve) ──────────────────────────────────────────────
PENSIEVE_BIND_ADDR=127.0.0.1:8080
# Comma-separated tokens; generate with: openssl rand -hex 32
PENSIEVE_API_TOKENS=dev-token
# SQLite relay-stats DB written by the ingester; read by relay endpoints.
RELAY_DB_PATH=./data/relay-stats.db

# ── Preview server (pensieve-preview), optional ──────────────────────────────
PREVIEW_BIND_ADDR=127.0.0.1:8081
PREVIEW_BASE_URL=http://localhost:8081
PREVIEW_SITE_NAME=Nostr Preview
