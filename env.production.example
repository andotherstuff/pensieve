# Pensieve — PRODUCTION environment template
#
# Production secrets live OUTSIDE the repo at /etc/pensieve/pensieve.env.
# Copy this template there and edit (mode 600, owned by the pensieve user):
#   sudo install -D -m 600 -o pensieve -g pensieve env.production.example /etc/pensieve/pensieve.env
#   sudo -u pensieve nano /etc/pensieve/pensieve.env
#
# Both the Docker stack (compose --env-file) and the native binaries
# (ingester/API/preview, via systemd EnvironmentFile) read it from there.
#
# For LOCAL native development, use env.local.example instead.

# ═══════════════════════════════════════════════════════════════════════════
# Domains / Reverse Proxy
# ═══════════════════════════════════════════════════════════════════════════
# For production, use your domains (Caddy auto-provisions HTTPS for both).
DOMAIN=api.example.com
# Preview domain (separate domain for public Nostr event preview pages)
PREVIEW_DOMAIN=preview.example.com

# ═══════════════════════════════════════════════════════════════════════════
# ClickHouse
# ═══════════════════════════════════════════════════════════════════════════
CLICKHOUSE_URL=http://localhost:8123
# The Pensieve binaries read CLICKHOUSE_DATABASE. (The ClickHouse container's
# own init database name is hardcoded in ops/production/compose.yml.)
CLICKHOUSE_DATABASE=nostr

# Password for the read-only 'grafana' user (used by Grafana dashboards)
# Generate a secure password: openssl rand -base64 24
CLICKHOUSE_GRAFANA_PASSWORD=changeme

# ═══════════════════════════════════════════════════════════════════════════
# API Server (pensieve-serve)
# ═══════════════════════════════════════════════════════════════════════════
PENSIEVE_BIND_ADDR=0.0.0.0:8080
# API tokens (comma-separated). Each user/client should have their own token.
# Generate tokens with: openssl rand -hex 32
PENSIEVE_API_TOKENS=your-secret-token-here

# ═══════════════════════════════════════════════════════════════════════════
# Preview Server (pensieve-preview)
# ═══════════════════════════════════════════════════════════════════════════
PREVIEW_BIND_ADDR=0.0.0.0:8081
# Base URL for canonical links and OG tags (no trailing slash)
PREVIEW_BASE_URL=https://preview.example.com
PREVIEW_SITE_NAME=Nostr Preview
# Path to VIP pubkeys file — one pubkey per line, hex or npub (optional).
# See ops/production/.vip.example for format.
# PREVIEW_VIP_FILE=/home/pensieve/pensieve/.vip

# ═══════════════════════════════════════════════════════════════════════════
# Ingester
# ═══════════════════════════════════════════════════════════════════════════
ROCKSDB_PATH=/data/rocksdb
ARCHIVE_PATH=/archive/segments
SEGMENT_SIZE=268435456  # 256 MB

# ═══════════════════════════════════════════════════════════════════════════
# Storage Box (for remote archive sync)
# ═══════════════════════════════════════════════════════════════════════════
STORAGE_BOX_HOST=uXXXXXX.your-storagebox.de
STORAGE_BOX_USER=uXXXXXX
STORAGE_BOX_PATH=pensieve/archive
# How many days to keep segments locally before allowing deletion
LOCAL_RETENTION_DAYS=30
# Disk usage threshold (%) to trigger cleanup of old local segments
DISK_CLEANUP_THRESHOLD=80

# ═══════════════════════════════════════════════════════════════════════════
# Monitoring (optional)
# ═══════════════════════════════════════════════════════════════════════════
# GRAFANA_PASSWORD=changeme

# ═══════════════════════════════════════════════════════════════════════════
# Backfill (for S3 source, optional)
# ═══════════════════════════════════════════════════════════════════════════
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_PREFIX=
